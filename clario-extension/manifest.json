{
  "manifest_version": 3,
  "name": "ClarioNot Clip",
  "version": "1.0.7",
  "action": { "default_title": "ClarioNot Clip" },
  "permissions": ["contextMenus", "storage", "tabs"],
  "host_permissions": ["https://clarionot.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://clarionot.com/*",
        "https://www.clarionot.com/*",
        "http://localhost:3000/*"
      ],

      "js": ["content/modal.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://clarionot.com/extension/connect*",
        "http://localhost:3000/extension/connect*"
      ],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    }
  ]
}
