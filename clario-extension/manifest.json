{
  "manifest_version": 3,
  "name": "ClarioNot Clip",
  "version": "1.0.7",
  "action": { "default_title": "ClarioNot Clip" },
  "permissions": ["contextMenus", "storage", "tabs"],
  "host_permissions": ["https://clarionot.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/bridge.js", "content/modal.js"],
      "run_at": "document_idle"
    }
  ]
}
