{
  "manifest_version": 3,
  "name": "clarionot Clip",
  "version": "1.0.6",
  "description": "Right-click to save links/notes to clarionot.",
  "permissions": ["contextMenus", "storage", "tabs"],
  "host_permissions": ["https://clarionot.com/*"],
  "background": { "service_worker": "background.js" },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://clarionot.com/extension/connect"],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    }
  ]
}
