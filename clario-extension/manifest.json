{
  "manifest_version": 3,
  "name": "Clario Clip",
  "version": "1.0.2",
  "description": "Right-click to save links/notes to Clario.",
  "permissions": ["contextMenus", "storage", "activeTab", "tabs"],
  "host_permissions": ["https://clasio.netlify.app/*"],
  "background": { "service_worker": "background.js" },

  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://clasio.netlify.app/extension/connect*"],
      "js": ["content.js"]
    }
  ]
}
